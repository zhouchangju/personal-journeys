{
  "name": "personal-journeys",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "pnpm --filter @journeys/toefl-2026 dev",
    "dev:toefl": "pnpm --filter @journeys/toefl-2026 dev",
    "validate": "node scripts/validate-journeys.mjs",
    "build": "pnpm validate && node scripts/build-all.mjs",
    "build:toefl": "pnpm --filter @journeys/toefl-2026 build",
    "create:journey": "node scripts/create-journey.mjs",
    "export:homepage": "pnpm validate && node scripts/export-homepage-catalog.mjs",
    "preview": "pnpm build && node scripts/preview.mjs",
    "test": "pnpm validate && node --test tests/*.test.mjs"
  }
}
